---
// In astro-portabletext, the raw block object data is automatically passed under Astro.props.node
const { node } = Astro.props;
---

<div style="background: #111; color: #fff; border-left: 5px solid #ff4500; padding: 1.5rem; margin: 2rem 0; border-radius: 4px; font-family: monospace;">
  <strong style="color: #ff4500; text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 0.5rem;">💣 KNOWLEDGE BOMB:</strong>
  <p style="margin: 0; font-size: 1.1rem; line-height: 1.5;">{node.text}</p>
</div>