---
interface Experiment {
  _id: string
  title: string
  slug: string
  overview: string
  targetDays: number
  logCount: number
}

interface Props {
  experiment: Experiment | null
}

const { experiment } = Astro.props

const progress = experiment
  ? Math.min(Math.round((experiment.logCount / experiment.targetDays) * 100), 100)
  : 0
---

<section class="lab-section">
  <div class="wrap">
    <div class="lab-grid">

      <div class="lab-purpose">
        <h2 class="section-label">What this is</h2>
        <p>I got tired of polished fitness content. This blog is the raw version — real experiments, real data, real results.</p>
        <p class="muted">Between experiments I write about discipline, output, and building the kind of life that actually fits.</p>
      </div>

      {experiment ? (
        <div class="experiment-card">
          <div class="card-header">
            <span class="section-label accent">Current experiment</span>
            <span class="status-badge">Active</span>
          </div>

          <h3 class="experiment-title">{experiment.title}</h3>

          {experiment.overview && (
            <p class="experiment-overview">{experiment.overview}</p>
          )}

          <div class="progress-meta">
            <span>Day {experiment.logCount} of {experiment.targetDays}</span>
            <span class="accent">{progress}%</span>
          </div>
          <div class="progress-track">
            <div class="progress-fill" style={`width: ${progress}%`}></div>
          </div>

          <a href={`/experiments/${experiment.slug}`} class="card-link">
            Read the daily logs →
          </a>
        </div>
      ) : (
        <div class="experiment-card experiment-card--empty">
          <p class="muted">No active experiment right now. Check back soon.</p>
        </div>
      )}

    </div>
  </div>
</section>

<style>
  .lab-section {
    padding: var(--space-16) 0;
    margin-inline: var(--space-16);
    border-top: 1px solid var(--color-border);
    margin-bottom: 3.25rem;
  }

  .lab-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .lab-purpose {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .lab-purpose p {
    font-size: var(--text-base);
    line-height: var(--leading-loose);
    margin: 0;
  }

  .experiment-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-6);
  }

  .experiment-card--empty {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 160px;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-4);
  }

  .status-badge {
    background: #1a2414;
    color: #7ab852;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: var(--radius-sm);
  }

  .experiment-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-optical-sizing: auto;
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .experiment-overview {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-4);
  }

  .progress-meta {
    display: flex;
    justify-content: space-between;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .progress-track {
    height: 2px;
    background: var(--color-border);
    border-radius: 2px;
    margin-bottom: var(--space-6);
  }

  .progress-fill {
    height: 2px;
    background: var(--color-accent);
    border-radius: 2px;
    transition: width 0.3s ease;
  }

  .card-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
  }

  .card-link:hover {
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .lab-grid {
      grid-template-columns: 1fr;
    }
  }
</style>