---
import { sanityClient } from '../../lib/sanity';
// import createClient from "@sanity/client"
import { PortableText } from "astro-portabletext";
import KnowledgeBomb from '../../components/KnowledgeBomb.astro';
import PortableTextImage from "../../components/PortableTextImage.astro";

export async function getStaticPaths() {
  const logs = await sanityClient.fetch(`*[_type == "dailyLog"]{ "slug": slug.current }`);
  return logs.map((log) => ({
    params: { slug: log.slug },
  }));
}

const { slug } = Astro.params;

const logQuery = `*[_type == "dailyLog" && slug.current == $slug][0]{
  dayNumber,
  title,
  date,
  weight,
  calories,
  vibe,
  content,
  "experimentTitle": experiment->title
}`;

const log = await sanityClient.fetch(logQuery, { slug });

if (!log) {
  return Astro.redirect("/404");
}

const portableTextComponents = {
  type: { 
    knowledgeBomb: KnowledgeBomb,
    image: PortableTextImage }
};

const formattedDate = new Date(log.date).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Day {log.dayNumber} {log.experimentTitle} | Smaller Stronger Shredded</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #0d0d0d;
      color: #e8e8e8;
      font-family: 'Georgia', serif;
      line-height: 1.7;
    }

    /* — Page banner above main — */
    .page-banner {
      background: #0d0d0d;
      border-bottom: 1px solid #1f1f1f;
      padding: 1.25rem 2rem;
      display: flex;
      align-items: baseline;
      gap: 1rem;
    }

    .page-banner .site-label {
      font-family: 'Courier New', monospace;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #9f9f9f;
    }

    .page-banner .entry-label {
      font-family: 'Courier New', monospace;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #ff4500;
    }

    /* — Layout — */
    .wrapper {
      max-width: 700px;
      margin: 0 auto;
      padding: 4rem 2rem 6rem;
    }

    /* — Header — */
    .entry-header {
      margin-bottom: 3rem;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid #1f1f1f;
    }

    .entry-meta {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.25rem;
    }

    .day-number {
      font-family: 'Courier New', monospace;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #ff4500;
    }

    .entry-date {
      font-family: 'Courier New', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      color: #9f9f9f;
    }

    .experiment-tag {
      font-family: 'Courier New', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      color: #9f9f9f;
      border: 1px solid #222;
      padding: 0.2em 0.6em;
      border-radius: 2px;
      margin-left: auto;
    }

    .entry-title {
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      font-weight: 400;
      line-height: 1.2;
      letter-spacing: -0.02em;
      color: #fff;
    }

    /* — Stats — */
    .stats {
      display: flex;
      gap: 0;
      margin-bottom: 3.5rem;
      border: 1px solid #1f1f1f;
      border-radius: 6px;
      overflow: hidden;
    }

    .stat {
      flex: 1 1 0;
      padding: 1.25rem 1rem;
      text-align: center;
      min-width: 0;
    }

    .stat + .stat {
      border-left: 1px solid #1f1f1f;
    }

    .stat-label {
      font-family: 'Courier New', monospace;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #fff;
      display: block;
      font-weight: 800;
      margin-bottom: 0.5rem;
      white-space: nowrap;
    }

    .stat-value {
      font-size: 1.5rem;
      font-weight: 700;
      color: #fff;
      display: block;
      white-space: nowrap;
    }

    .stat-value.accent {
      color: #ff4500;
    }

    .stat-empty {
      color: #333;
    }

    /* — Body copy — */
    .entry-body {
      font-size: 1.1rem;
      color: #ccc;
    }

    .entry-body p {
      margin-bottom: 1.5rem;
    }

    .entry-body h2 {
      font-size: 1.3rem;
      color: #fff;
      margin: 2.5rem 0 1rem;
      font-weight: 400;
      letter-spacing: -0.01em;
    }

    .entry-body strong { color: #fff; }

    .entry-body a {
      color: #ff4500;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .empty-note {
      font-style: italic;
      color: #333;
    }

    /* — Footer nav — */
    .entry-footer {
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid #1f1f1f;
    }

    .back-link {
      font-family: 'Courier New', monospace;
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #ff4500;
      text-decoration: none;
    }

    .back-link:hover {
      text-decoration: underline;
      text-underline-offset: 3px;
    }
  </style>
</head>
<body>

  <div class="page-banner">
    <span class="site-label">Smaller Stronger Shredded</span>
    <span class="entry-label">Day {log.dayNumber}</span>
  </div>

  <div class="wrapper">

    <header class="entry-header">
      <div class="entry-meta">
        <span class="day-number">Day {log.dayNumber}</span>
        <span class="entry-date">{formattedDate}</span>
        {log.experimentTitle && (
          <span class="experiment-tag">{log.experimentTitle}</span>
        )}
      </div>
      <h1 class="entry-title">{log.title}</h1>
    </header>

    <div class="stats">
      <div class="stat">
        <span class="stat-label">Weight</span>
        {log.weight
          ? <span class="stat-value">{log.weight}<small style="font-size:0.9rem;color:#555;"> kg</small></span>
          : <span class="stat-value stat-empty">—</span>
        }
      </div>
      <div class="stat">
        <span class="stat-label">Calories</span>
        {log.calories
          ? <span class="stat-value">{log.calories}<small style="font-size:0.9rem;color:#555;"> kcal</small></span>
          : <span class="stat-value stat-empty">—</span>
        }
      </div>
      <div class="stat">
        <span class="stat-label">Vibe</span>
        {log.vibe
          ? <span class="stat-value accent">{log.vibe}<small style="font-size:0.9rem;color:#555;">/10</small></span>
          : <span class="stat-value stat-empty">—</span>
        }
      </div>
    </div>

    <article class="entry-body">
      {log.content
        ? <PortableText value={log.content} components={portableTextComponents} />
        : <p class="empty-note">No thoughts logged for this day.</p>
      }
    </article>

    <footer class="entry-footer">
      <a href="/logs" class="back-link">← Back to timeline</a>
    </footer>

  </div>

</body>
</html>