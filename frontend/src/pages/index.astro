---
import { createClient } from '@sanity/client';

const sanityClient = createClient({
  projectId: import.meta.env.PUBLIC_SANITY_PROJECT_ID,
  dataset: import.meta.env.PUBLIC_SANITY_DATASET,
  apiVersion: '2024-03-15',
  useCdn: false,
});

const query = `*[_type == "dailyLog"] | order(date desc) {
  _id,
  "slug": slug.current,
  date,
  dayNumber,
  title,
  weight,
  calories,
  vibe,
  content
}`;

const logs = await sanityClient.fetch(query);
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Smaller Stronger Shredded | The Timeline</title>
</head>
<body style="background: #111; color: #eee; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; line-height: 1.7; margin: 0; padding: 4rem 2rem;">

  <div style="max-width: 650px; margin: 0 auto;">
    
    <header style="margin-bottom: 5rem;">
      <h1 style="font-size: 2.2rem; font-weight: 800; letter-spacing: -0.02em; margin: 0 0 0.5rem 0; color: #fff; text-transform: uppercase;">
        Smaller Stronger Shredded
      </h1>
      <p style="color: #888; font-size: 1.05rem; margin: 0; font-style: italic;">
        The experiment timeline. Ordered by day.
      </p>
    </header>

    <main style="display: flex; flex-direction: column; gap: 2.5rem; border-left: 1px solid #333; padding-left: 1.5rem; margin-left: 0.5rem;">
      
      {logs.length === 0 ? (
        <p style="color: #666; font-style: italic;">No logs found. Ensure you have published documents inside Sanity Studio.</p>
      ) : (
        logs.map((log) => (
          <article style="position: relative;">
            
            <div style="position: absolute; left: calc(-1.5rem - 5px); top: 8px; width: 9px; height: 9px; background: #ff4500; border-radius: 50%;"></div>
            
            <h2 style="margin: 0 0 0.5rem 0; font-size: 1.35rem; font-weight: 700; line-height: 1.3;">
              <a href={`/logs/${log.slug}`} style="color: #fff; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#ff4500'" onmouseout="this.style.color='#fff'">
                Day {log.dayNumber}: {log.title}
              </a>
            </h2>
            
            <div style="display: flex; gap: 1rem; align-items: center; font-size: 0.85rem; color: #888; font-family: monospace; text-transform: uppercase; margin-bottom: 0.5rem;">
              <span>{log.date}</span>
              {log.weight && <span>• {log.weight}kg</span>}
              {log.calories && <span>• {log.calories}kcal</span>}
              {log.vibe && <span>• Vibe: {log.vibe}/10</span>}
            </div>
            
            <a href={`/logs/${log.slug}`} style="font-size: 0.9rem; color: #ff4500; text-decoration: none; font-weight: 600;">
              Read Entry →
            </a>

          </article>
        ))
      )}

    </main>

  </div>

</body>
</html>